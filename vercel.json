{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!assets/|motion/|audio/|hero/|store/|favicon\\.svg|og-image\\.svg).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
